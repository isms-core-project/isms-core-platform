def main(output_dir: Path = _wkbk_dir, date_str: str | None = None):
    if date_str:
        ts = date_str
    else:
        ts = GENERATED_TIMESTAMP
    filename = f"{DOCUMENT_ID}_{WORKBOOK_NAME.replace(' ', '_')}_{ts}.xlsx"

    logger.info("%s  Generating %s ...", CHECK, filename)

    wb = Workbook()

    # Sheet 1: Instructions & Legend (uses default sheet)
    create_instructions_sheet(wb.active)

    # Data sheets
{% for sheet in input_sheets %}    {{ sheet.fn_name }}(wb)
{% endfor %}
    # Standard sheets — order: ER → SD → AS (GS-TAB-003)
{% if has_standard_er %}    create_evidence_register(wb.create_sheet("Evidence Register"))
{% endif %}{% if has_summary %}    create_summary_dashboard(wb)
{% endif %}{% if has_standard_as %}    create_approval_sheet(wb.create_sheet("Approval Sign-Off"))
{% endif %}

    finalize_validations(wb)

    out_path = output_dir / filename
    wb.save(out_path)
    logger.info("%s  Saved: %s", CHECK, out_path)
    return out_path


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description=f"Generate {DOCUMENT_ID} workbook")
    parser.add_argument("--output", type=Path, default=_wkbk_dir, help="Output directory")
    parser.add_argument("--date",   type=str,  default=None,       help="Date suffix YYYYMMDD")
    args = parser.parse_args()
    main(output_dir=args.output, date_str=args.date)

