{% for sheet in input_sheets %}

def {{ sheet.fn_name }}(wb):
    """Create '{{ sheet.name }}' data sheet."""
    ws = wb.create_sheet("{{ sheet.name }}")
    ws.sheet_view.showGridLines = False
    styles      = create_styles()
    thin        = Side(style="thin")
    data_border = Border(left=thin, right=thin, top=thin, bottom=thin)
    yellow      = PatternFill(start_color="FFFFCC", end_color="FFFFCC", fill_type="solid")
    grey_fill   = PatternFill(start_color="F2F2F2", end_color="F2F2F2", fill_type="solid")

    col_count = {{ sheet.col_count }}
    ws.merge_cells(f"A1:{get_column_letter(col_count)}1")
    cell           = ws["A1"]
    cell.value     = "{{ sheet.name | upper }}"
    cell.font      = Font(bold=True, size=14, color="FFFFFF", name="Calibri")
    cell.fill      = PatternFill(start_color="003366", end_color="003366", fill_type="solid")
    cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
    cell.border    = data_border
    ws.row_dimensions[1].height = 35

    ws.merge_cells(f"A2:{get_column_letter(col_count)}2")
    ws["A2"] = "{{ sheet.name }} — {{ control_id }}: {{ control_name }}"
    ws["A2"].font = Font(italic=True, size=10, name="Calibri")

    headers = {{ sheet.col_headers | list }}
    for col_idx, hdr in enumerate(headers, 1):
        c = ws.cell(row=3, column=col_idx, value=hdr)
        c.font      = styles["column_header"]["font"]
        c.fill      = styles["column_header"]["fill"]
        c.alignment = styles["column_header"]["alignment"]
        c.border    = styles["column_header"]["border"]

{% if sheet.dv_cols %}    # Data validations (from workbook schema)
{% for dv in sheet.dv_cols %}    _dv_{{ loop.index }} = DataValidation(type="list", formula1='"{{ dv.dv_list | join(",") }}"', allow_blank=True)
    ws.add_data_validation(_dv_{{ loop.index }})
{% endfor %}{% endif %}
    # Row 4: grey sample row
    for col_idx in range(1, col_count + 1):
        c           = ws.cell(row=4, column=col_idx)
        c.value     = "{{ sheet.id_prefix }}-001" if col_idx == 1 else ""
        c.fill      = grey_fill
        c.font      = Font(name="Calibri", size=10, color="808080", italic=True)
        c.border    = data_border
        c.alignment = Alignment(horizontal="left", vertical="center", wrap_text=True)
{% if sheet.dv_cols %}{% for dv in sheet.dv_cols %}    _dv_{{ loop.index }}.add(ws.cell(row=4, column={{ dv.col_idx }}))
{% endfor %}{% endif %}
    # Rows 5-54: 50 empty FFFFCC input rows
    for r in range(5, 55):
        for col_idx in range(1, col_count + 1):
            cell        = ws.cell(row=r, column=col_idx)
            cell.fill   = yellow
            cell.font   = Font(name="Calibri")
            cell.border = data_border
{% if sheet.dv_cols %}{% for dv in sheet.dv_cols %}        _dv_{{ loop.index }}.add(ws.cell(row=r, column={{ dv.col_idx }}))
{% endfor %}{% endif %}
    set_column_widths(ws, {{ sheet.col_widths }})
    ws.freeze_panes = {% if sheet.freeze_panes and sheet.freeze_panes != 'None' %}"{{ sheet.freeze_panes }}"{% else %}None{% endif %}
    return ws
{% endfor %}
{% if has_summary %}

def create_summary_dashboard(wb):
    """Create Summary Dashboard sheet — TABLE 1 / TABLE 2 / TABLE 3 structure."""
    ws = wb.create_sheet("Summary Dashboard")
    ws.sheet_view.showGridLines = False
    thin        = Side(style="thin")
    THIN_BORDER = Border(left=thin, right=thin, top=thin, bottom=thin)
    navy_fill   = PatternFill(start_color="003366", end_color="003366", fill_type="solid")
    grey_fill   = PatternFill(start_color="D9D9D9", end_color="D9D9D9", fill_type="solid")
    red_fill    = PatternFill(start_color="C00000", end_color="C00000", fill_type="solid")
    yellow_fill = PatternFill(start_color="FFFFCC", end_color="FFFFCC", fill_type="solid")

    # ── Row 1: Title ──────────────────────────────────────────────────────────
    ws.merge_cells("A1:G1")
    ws["A1"] = f"{{ workbook_name | upper }} — SUMMARY DASHBOARD"
    ws["A1"].font      = Font(bold=True, size=14, color="FFFFFF", name="Calibri")
    ws["A1"].fill      = navy_fill
    ws["A1"].alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
    ws["A1"].border    = THIN_BORDER
    ws.row_dimensions[1].height = 35

    # ── Row 2: Control reference ──────────────────────────────────────────────
    ws.merge_cells("A2:G2")
    ws["A2"] = CONTROL_REF
    ws["A2"].font      = Font(name="Calibri", size=10, italic=True, color="003366")
    ws["A2"].alignment = Alignment(horizontal="left", vertical="center")

    # ── TABLE 1: Assessment Area Compliance Overview (row 4+) ─────────────────
    ws.merge_cells("A4:G4")
    ws["A4"] = "TABLE 1: ASSESSMENT AREA COMPLIANCE OVERVIEW"
    ws["A4"].font = Font(bold=True, size=11, color="FFFFFF")
    ws["A4"].fill = navy_fill

    t1_headers = ["Assessment Area", "Total Items", "Compliant", "Partial",
                  "Non-Compliant", "N/A", "Compliance %"]
    for col, hdr in enumerate(t1_headers, 1):
        c = ws.cell(row=5, column=col, value=hdr)
        c.font      = Font(bold=True, color="000000")
        c.fill      = grey_fill
        c.border    = THIN_BORDER
        c.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)

    # One row per data sheet — status and count columns from workbook schema
    area_sheets = [
{% for sheet in input_sheets %}        ("{{ sheet.name }}", "{{ sheet.status_col_letter }}", "{{ sheet.count_col_letter }}"),
{% endfor %}
    ]
    for i, (area, status_col, count_col) in enumerate(area_sheets):
        r = 6 + i
        ws.cell(row=r, column=1, value=area).border = THIN_BORDER

        cell_b = ws.cell(row=r, column=2, value=f"=COUNTA('{area}'!{count_col}5:{count_col}54)")
        cell_b.border = THIN_BORDER
        cell_b.alignment = Alignment(horizontal="center")

        cell_c = ws.cell(row=r, column=3, value=f"=COUNTIF('{area}'!{status_col}5:{status_col}54,\"{CHECK} Compliant\")")
        cell_c.border = THIN_BORDER
        cell_c.alignment = Alignment(horizontal="center")

        cell_d = ws.cell(row=r, column=4, value=f"=COUNTIF('{area}'!{status_col}5:{status_col}54,\"{WARNING} Partial\")")
        cell_d.border = THIN_BORDER
        cell_d.alignment = Alignment(horizontal="center")

        cell_e = ws.cell(row=r, column=5, value=f"=COUNTIF('{area}'!{status_col}5:{status_col}54,\"{XMARK} Non-Compliant\")")
        cell_e.border = THIN_BORDER
        cell_e.alignment = Alignment(horizontal="center")

        cell_f = ws.cell(row=r, column=6, value=f"=COUNTIF('{area}'!{status_col}5:{status_col}54,\"N/A\")")
        cell_f.border = THIN_BORDER
        cell_f.alignment = Alignment(horizontal="center")

        cell_g = ws.cell(row=r, column=7, value=f"=IF((B{r}-F{r})=0,0,C{r}/(B{r}-F{r}))")
        cell_g.number_format = "0.0%"
        cell_g.border = THIN_BORDER
        cell_g.alignment = Alignment(horizontal="center")

    total_r = 6 + len(area_sheets)
    for col in range(1, 8):
        c = ws.cell(row=total_r, column=col)
        c.fill   = grey_fill
        c.border = THIN_BORDER
        c.font   = Font(bold=True, color="000000")
        c.alignment = Alignment(horizontal="center")
    ws.cell(row=total_r, column=1, value="TOTAL")
    for col in range(2, 7):
        ws.cell(row=total_r, column=col).value = f"=SUM({get_column_letter(col)}6:{get_column_letter(col)}{total_r - 1})"
    ws.cell(row=total_r, column=7).value = f"=IF((B{total_r}-F{total_r})=0,0,C{total_r}/(B{total_r}-F{total_r}))"
    ws.cell(row=total_r, column=7).number_format = "0.0%"

    # ── TABLE 2: Key Metrics (row total_r + 2) ────────────────────────────────
    m_start = total_r + 2
    ws.merge_cells(f"A{m_start}:G{m_start}")
    ws[f"A{m_start}"] = "TABLE 2: KEY METRICS"
    ws[f"A{m_start}"].font = Font(bold=True, size=11, color="FFFFFF")
    ws[f"A{m_start}"].fill = navy_fill

    for col, hdr in enumerate(["Metric", "Value", "", "", "", "", ""], 1):
        c = ws.cell(row=m_start + 1, column=col, value=hdr or None)
        c.font   = Font(bold=True, color="000000")
        c.fill   = grey_fill
        c.border = THIN_BORDER
        c.alignment = Alignment(horizontal="center")

    # Key metrics per data sheet
    metrics = []
    for area, status_col, count_col in area_sheets:
        metrics.append((f"{area} — Total Entries",     f"=COUNTA('{area}'!{count_col}5:{count_col}54)"))
        metrics.append((f"{area} — Compliant",         f"=COUNTIF('{area}'!{status_col}5:{status_col}54,\"{CHECK} Compliant\")"))
        metrics.append((f"{area} — Non-Compliant",     f"=COUNTIF('{area}'!{status_col}5:{status_col}54,\"{XMARK} Non-Compliant\")"))

    row = m_start + 2
    for metric, formula in metrics:
        ws.cell(row=row, column=1, value=metric).border = THIN_BORDER
        v = ws.cell(row=row, column=2, value=formula)
        v.border = THIN_BORDER
        v.alignment = Alignment(horizontal="center")
        for col in range(3, 8):
            ws.cell(row=row, column=col).border = THIN_BORDER
        row += 1

    # 2 buffer rows
    for _ in range(2):
        for col in range(1, 8):
            ws.cell(row=row, column=col).border = THIN_BORDER
        row += 1

    # ── TABLE 3: Critical Findings (row + 1) ──────────────────────────────────
    c_start = row + 1
    ws.merge_cells(f"A{c_start}:G{c_start}")
    ws[f"A{c_start}"] = "TABLE 3: CRITICAL FINDINGS REQUIRING IMMEDIATE ATTENTION"
    ws[f"A{c_start}"].font = Font(bold=True, size=11, color="FFFFFF")
    ws[f"A{c_start}"].fill = red_fill

    for col, hdr in enumerate(["Category", "Finding", "Count", "Severity", "Action Required", "", ""], 1):
        c = ws.cell(row=c_start + 1, column=col, value=hdr or None)
        c.font   = Font(bold=True, color="000000")
        c.fill   = grey_fill
        c.border = THIN_BORDER
        c.alignment = Alignment(horizontal="center")

    # Critical findings per data sheet
    findings = []
    for area, status_col, count_col in area_sheets:
        findings.append((area, f"Non-compliant items in {area}",
                         f"=COUNTIF('{area}'!{status_col}5:{status_col}54,\"{XMARK} Non-Compliant\")",
                         "High", "Review and remediate"))

    row = c_start + 2
    for cat, finding, formula, severity, action in findings:
        for col in range(1, 8):
            ws.cell(row=row, column=col).fill   = yellow_fill
            ws.cell(row=row, column=col).border = THIN_BORDER
        ws.cell(row=row, column=1, value=cat)
        ws.cell(row=row, column=2, value=finding)
        cnt = ws.cell(row=row, column=3, value=formula)
        cnt.alignment = Alignment(horizontal="center")
        ws.cell(row=row, column=4, value=severity)
        ws.cell(row=row, column=5, value=action)
        row += 1

    # 2 buffer rows
    for _ in range(2):
        for col in range(1, 8):
            ws.cell(row=row, column=col).fill   = yellow_fill
            ws.cell(row=row, column=col).border = THIN_BORDER
        row += 1

    # ── Column widths & freeze ────────────────────────────────────────────────
    ws.column_dimensions["A"].width = 50
    ws.column_dimensions["B"].width = 18
    ws.column_dimensions["C"].width = 16
    ws.column_dimensions["D"].width = 18
    ws.column_dimensions["E"].width = 18
    ws.column_dimensions["F"].width = 12
    ws.column_dimensions["G"].width = 15
    ws.freeze_panes = "A4"
    return ws
