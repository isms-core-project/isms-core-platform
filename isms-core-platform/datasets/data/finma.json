      "parent_id": "60494a0d-3bbc-576e-8d1b-220533af6919",
      "control_id": "P1",
      "title": "Operational Risk Management",
      "description": "Board approves risk tolerance; executive board implements procedures, processes, controls. Independent audit function. Regular risk reporting. Separation of operational management from independent control functions.",
      "level": 1,
      "sort_order": 200,
      "metadata": {
        "sub_framework": "FINMA_2023_1"
      }
    },
    {
      "type": "framework_control",
      "id": "cb28be68-7163-5a35-bd5c-fc37e916b921",
      "framework_id": "5ef8740e-ae06-53ea-abd2-fa496cca9530",
      "parent_id": "60494a0d-3bbc-576e-8d1b-220533af6919",
      "control_id": "P2",
      "title": "ICT Risk Management",
      "description": "ICT strategy and governance aligned to business strategy. Change management, ICT operations, incident management. Comprehensive ICT asset inventory. Annual ICT risk reporting.",
      "level": 1,
      "sort_order": 300,
      "metadata": {
        "sub_framework": "FINMA_2023_1"
      }
    },
    {
      "type": "framework_control",
      "id": "2bdf3038-a2d5-5687-9732-1eff5b6c908e",
      "framework_id": "5ef8740e-ae06-53ea-abd2-fa496cca9530",
      "parent_id": "60494a0d-3bbc-576e-8d1b-220533af6919",
      "control_id": "P3",
      "title": "Cyber Risk Management",
      "description": "Threat identification and asset protection. Vulnerability analyses and penetration testing. Systematic monitoring of ICT systems. Incident response plans tested. Cyber attacks reported to FINMA within 24 hours.",
      "level": 1,
      "sort_order": 400,
      "metadata": {
        "sub_framework": "FINMA_2023_1"
      }
    },
    {
      "type": "framework_control",
      "id": "8a15e863-7351-51bb-89cc-3b93c223ae90",
      "framework_id": "5ef8740e-ae06-53ea-abd2-fa496cca9530",
      "parent_id": "60494a0d-3bbc-576e-8d1b-220533af6919",
      "control_id": "P4",
      "title": "Critical Data Risk Management",
      "description": "Protection of confidentiality, integrity, and availability of critical data. Data strategy. Service provider due diligence. Potential dual reporting obligations (FINMA + data protection).",
      "level": 1,
      "sort_order": 500,
      "metadata": {
        "sub_framework": "FINMA_2023_1"
      }
    },
    {
      "type": "framework_control",
      "id": "2e5e12b5-0732-5b73-bbe5-3b723ff944f1",
      "framework_id": "5ef8740e-ae06-53ea-abd2-fa496cca9530",
      "parent_id": "60494a0d-3bbc-576e-8d1b-220533af6919",
      "control_id": "P5",
      "title": "Business Continuity Management",
      "description": "Identification of critical business processes with RTO/RPO. Mandatory BCP and DRP. Annual review plus ad hoc updates. Testing against severe but plausible scenarios.",
      "level": 1,
      "sort_order": 600,
      "metadata": {
        "sub_framework": "FINMA_2023_1"
      }
    },
    {
      "type": "framework_control",
      "id": "a78e36b2-0985-5079-8b61-ce0aa0d35c69",
      "framework_id": "5ef8740e-ae06-53ea-abd2-fa496cca9530",
      "parent_id": "60494a0d-3bbc-576e-8d1b-220533af6919",
      "control_id": "P6",
      "title": "International Service Business Risks",
      "description": "Management of risks from cross-border financial services. Legal, regulatory, and reputational risk assessment for international operations.",
      "level": 1,
      "sort_order": 700,
      "metadata": {
        "sub_framework": "FINMA_2023_1"
      }
    },
    {
      "type": "framework_control",
      "id": "ac92a71b-0485-5c03-83b3-f4e864cb6fa2",
      "framework_id": "5ef8740e-ae06-53ea-abd2-fa496cca9530",
      "parent_id": "60494a0d-3bbc-576e-8d1b-220533af6919",
      "control_id": "P7",
      "title": "Operational Resilience",
      "description": "Ability to restore critical functions within defined disruption tolerance. Board-approved tolerance thresholds per critical function. Regular testing under severe scenarios.",
      "level": 1,
      "sort_order": 800,
      "metadata": {
        "sub_framework": "FINMA_2023_1"
      }
    },
    {
      "type": "framework_control",
