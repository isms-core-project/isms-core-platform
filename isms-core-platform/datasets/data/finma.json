      "title": "FINMA Circular 2023/1 — Operational Risks and Resilience",
      "description": "FINMA Circular 2023/1 — Operational Risks and Resilience (2023/1)",
      "level": 0,
      "sort_order": 10000,
      "metadata": {
        "sub_framework": "FINMA_2023_1",
