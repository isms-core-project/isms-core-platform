      "control_id": "FINMA_2018_3",
      "title": "FINMA Circular 2018/3 — Outsourcing",
      "description": "FINMA Circular 2018/3 — Outsourcing (2018/3)",
      "level": 0,
      "sort_order": 90000,
      "metadata": {
        "sub_framework": "FINMA_2018_3",
        "version": "2018/3",
        "effective_date": "2018-04-01",
