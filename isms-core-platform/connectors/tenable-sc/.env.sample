# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000     # ISMS CORE API (LAN IP or hostname)
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Tenable Security Center (Tenable.sc)
# On-premises vulnerability management platform
TENABLE_SC_HOST=tenable-sc.corp.local
TENABLE_SC_PORT=443

# Auth — API key (preferred, Tenable.sc 5.13+):
#   System → Users → [user] → API Keys → Generate
TENABLE_SC_ACCESS_KEY=<access-key>
TENABLE_SC_SECRET_KEY=<secret-key>

# Auth — session token fallback (older Tenable.sc versions):
# TENABLE_SC_USERNAME=isms-readonly
# TENABLE_SC_PASSWORD=<password>

TENABLE_SC_VERIFY_SSL=true          # set false for self-signed certs
TENABLE_SC_VULN_LIMIT=1000          # max critical/high vuln rows to fetch

POLL_INTERVAL=86400                  # 24h — aligned with scan cadence
BATCH_SIZE=100
