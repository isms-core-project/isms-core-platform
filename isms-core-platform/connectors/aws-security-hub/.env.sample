# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000     # ISMS CORE API (LAN IP or hostname)
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# AWS Security Hub
# Option 1: Explicit credentials (least-privilege read-only IAM user recommended)
AWS_ACCESS_KEY_ID=<access-key-id>
AWS_SECRET_ACCESS_KEY=<secret-access-key>
AWS_DEFAULT_REGION=eu-west-2

# Option 2: IAM role assumption (cross-account or enhanced permissions)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/ISMS-SecurityHub-ReadOnly

# Option 3: Instance profile (running on EC2/ECS) — omit all AWS_* vars above

POLL_INTERVAL=86400                     # 24h
BATCH_SIZE=100
