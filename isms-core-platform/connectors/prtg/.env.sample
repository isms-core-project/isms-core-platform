# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# PRTG Network Monitor
PRTG_URL=https://prtg.corp.local
PRTG_API_TOKEN=<prtg-api-token-for-service-account>
# Alternative: username/password (use one or the other, API token preferred)
# PRTG_USERNAME=svc_isms
# PRTG_PASSWORD=<password>
PRTG_VERIFY_SSL=true   # set false for self-signed certificates

# Schedule (monitoring data changes often — 1h is reasonable)
POLL_INTERVAL=3600    # 1h
BATCH_SIZE=100
