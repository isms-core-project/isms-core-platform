# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Wazuh Manager API
WAZUH_URL=https://wazuh-manager.corp.local:55000
WAZUH_USERNAME=wazuh-wui
WAZUH_PASSWORD=<service-account-password>
WAZUH_VERIFY_SSL=true   # set false for self-signed certificates

# Schedule
POLL_INTERVAL=3600   # 1h — agent/alert data changes frequently
BATCH_SIZE=100
