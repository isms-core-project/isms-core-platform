# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Cisco ISE ERS API
# Enable: Administration → System → Settings → ERS Settings → Enable ERS for Read/Write
# Role required: ERS Admin (or ERS Operator for read-only)
CISCO_ISE_HOST=ise.corp.local
CISCO_ISE_USERNAME=isms-readonly
CISCO_ISE_PASSWORD=<password>
CISCO_ISE_VERIFY_SSL=true
# CISCO_ISE_ERS_PORT=9060      # ERS API port (default: 9060)
# CISCO_ISE_MNT_PORT=443       # MNT API port (default: 443)

POLL_INTERVAL=3600
BATCH_SIZE=100
