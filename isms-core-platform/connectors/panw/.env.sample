# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Palo Alto Networks PAN-OS
PANW_HOST=panos.corp.local
PANW_API_KEY=<api-key-from-GET-/api/?type=keygen>
PANW_VERIFY_SSL=true
PANW_VSYS=vsys1
# For Panorama deployment:
# PANW_PANORAMA=true
# PANW_TARGET_DEVICE=<managed-device-serial>

POLL_INTERVAL=3600
BATCH_SIZE=100
