# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Microsoft Intune — App Registration (same tenant as Entra ID)
INTUNE_TENANT_ID=<your-tenant-id>
INTUNE_CLIENT_ID=<your-client-id>
INTUNE_CLIENT_SECRET=<your-client-secret>

# Schedule
POLL_INTERVAL=86400   # 24h full sync
BATCH_SIZE=100
