# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Fortinet FortiGate
FORTIGATE_HOST=fortigate.corp.local
FORTIGATE_API_TOKEN=<rest-api-token-from-system-administrators>
FORTIGATE_VERIFY_SSL=true      # set false for self-signed certs
FORTIGATE_VDOM=root            # VDOM name (default: root)

POLL_INTERVAL=3600
BATCH_SIZE=100
