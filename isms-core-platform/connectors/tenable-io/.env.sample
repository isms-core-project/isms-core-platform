# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000     # ISMS CORE API (LAN IP or hostname)
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Tenable Vulnerability Management (Tenable.io — cloud)
# Generate API keys at: Settings → My Account → API Keys
TENABLE_ACCESS_KEY=<access-key>
TENABLE_SECRET_KEY=<secret-key>

POLL_INTERVAL=86400                     # 24h
BATCH_SIZE=100
