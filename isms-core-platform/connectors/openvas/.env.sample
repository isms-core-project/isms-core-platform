# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000     # ISMS CORE API (LAN IP or hostname)
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# OpenVAS / Greenbone Vulnerability Manager (GVM 22.4+)
# GSA REST API (served on port 9392 by default, or via reverse proxy)
OPENVAS_URL=https://greenbone.corp.local
OPENVAS_USERNAME=isms-readonly
OPENVAS_PASSWORD=<password>
OPENVAS_VERIFY_SSL=true                 # set false for self-signed certificates

POLL_INTERVAL=86400                     # 24h
BATCH_SIZE=100
