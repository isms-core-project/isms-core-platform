# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Jira Cloud
JIRA_URL=https://mycompany.atlassian.net
JIRA_USERNAME=isms-service@mycompany.com
JIRA_API_TOKEN=<api-token-from-id.atlassian.com>

# Jira Data Center (on-premises) — comment out cloud block above, use this instead:
# JIRA_URL=https://jira.corp.local
# JIRA_USERNAME=svc_isms
# JIRA_API_TOKEN=<personal-access-token-from-profile>

# Optional: restrict to specific projects
JIRA_JQL=project in (ITSEC, OPS)   # or leave blank for all
JIRA_LOOKBACK_DAYS=30

# Schedule
POLL_INTERVAL=3600   # 1h
BATCH_SIZE=100
