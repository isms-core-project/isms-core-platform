# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Active Directory / LDAP
AD_SERVER=dc01.corp.local
AD_PORT=389
AD_USE_SSL=false
AD_BIND_DN=CN=svc_isms,CN=Users,DC=corp,DC=local
AD_BIND_PASS=<service-account-password>
AD_BASE_DN=DC=corp,DC=local

# Schedule
POLL_INTERVAL=86400   # 24h full sync
BATCH_SIZE=100
