# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# OpenAEV (Filigran XTM — Adversary Emulation & Validation)
# Works with on-premises OpenAEV and OpenAEV Cloud
# Token: Profile → API key (top-right menu → profile icon)
OPENAEV_URL=https://openaev.corp.local
OPENAEV_TOKEN=<api-token-from-profile>
OPENAEV_VERIFY_SSL=true           # set false for self-signed certs
OPENAEV_MAX_EXERCISES=20          # number of completed exercises to fetch

POLL_INTERVAL=86400               # 24h — exercise data changes slowly
BATCH_SIZE=100
