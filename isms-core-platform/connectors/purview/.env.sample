# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Microsoft Purview / Entra App Registration
# Use the same App Registration as Entra ID / Defender / Sentinel / Intune
# Required permissions (Application):
#   InformationProtectionPolicy.Read.All   — sensitivity label inventory
#   RecordsManagement.Read.All             — retention labels
#   SecurityEvents.Read.All                — DLP / IP security alerts
PURVIEW_TENANT_ID=<azure-tenant-id>
PURVIEW_CLIENT_ID=<app-registration-client-id>
PURVIEW_CLIENT_SECRET=<app-registration-client-secret>

# Optional: Purview account name for Data Map / Collections evidence (a.8.12)
# Leave blank if you only use Microsoft Purview Compliance (Graph API)
# The managed identity or service principal needs: Purview Data Curator role
PURVIEW_ACCOUNT=                          # e.g. mycompany-purview

POLL_INTERVAL=86400                       # 24h — compliance state changes slowly
BATCH_SIZE=100
