# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Cisco ASA REST API
# Enable: configure terminal → rest-api enable
CISCO_ASA_HOST=asa.corp.local
CISCO_ASA_USERNAME=isms-readonly
CISCO_ASA_PASSWORD=<password>
CISCO_ASA_VERIFY_SSL=true
CISCO_ASA_PORT=443           # some ASA versions use 55443

POLL_INTERVAL=3600
BATCH_SIZE=100
