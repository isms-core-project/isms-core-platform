# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# GLPI
GLPI_URL=http://glpi.corp.local
GLPI_USER_TOKEN=<user-api-token-from-glpi-profile>
GLPI_APP_TOKEN=<application-token-from-glpi-api-settings>

# Schedule (asset inventories change infrequently)
POLL_INTERVAL=86400   # 24h
BATCH_SIZE=100
