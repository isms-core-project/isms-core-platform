# ISMS CORE API
ISMS_API_URL=http://10.0.0.110:8000     # ISMS CORE API (LAN IP or hostname)
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# GCP Security Command Center
GCP_PROJECT_ID=my-project-id
GCP_ORGANIZATION_ID=123456789012        # Numeric organization ID

# Service account key — paste the full contents of the JSON key file as a single line
# Generate at: IAM & Admin → Service Accounts → Keys → Add Key
# Required IAM roles on the organisation:
#   roles/securitycenter.findingsViewer
#   roles/securitycenter.assetsViewer
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Omit GCP_SERVICE_ACCOUNT_KEY if running on GCE/GKE with Workload Identity

POLL_INTERVAL=86400                     # 24h
BATCH_SIZE=100
