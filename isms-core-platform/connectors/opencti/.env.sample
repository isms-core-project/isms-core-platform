# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# OpenCTI (Filigran XTM)
# Works with on-premises OpenCTI and OpenCTI Cloud
# Token: Profile → API Access → Copy API key
OPENCTI_URL=https://opencti.corp.local
OPENCTI_TOKEN=<api-token-from-profile>
OPENCTI_VERIFY_SSL=true        # set false for self-signed certs

# Data limits (adjust to your platform size)
OPENCTI_INDICATOR_LIMIT=500    # max active indicators to fetch
OPENCTI_VULN_LIMIT=500         # max tracked CVEs to fetch
OPENCTI_INCIDENT_LIMIT=200     # max incidents to fetch

POLL_INTERVAL=3600              # 1h — threat intel updates frequently
BATCH_SIZE=100
