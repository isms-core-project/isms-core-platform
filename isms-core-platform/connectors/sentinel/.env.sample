# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# Microsoft Sentinel — App Registration
SENTINEL_TENANT_ID=<your-tenant-id>
SENTINEL_CLIENT_ID=<your-client-id>
SENTINEL_CLIENT_SECRET=<your-client-secret>

# Azure Resource IDs for the Sentinel workspace
SENTINEL_SUBSCRIPTION_ID=<your-subscription-id>
SENTINEL_RESOURCE_GROUP=<resource-group-name>
SENTINEL_WORKSPACE_NAME=<log-analytics-workspace-name>

# Schedule (1h — SIEM data changes frequently)
POLL_INTERVAL=3600
BATCH_SIZE=100
