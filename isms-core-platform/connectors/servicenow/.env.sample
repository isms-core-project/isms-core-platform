# ISMS CORE API
ISMS_API_URL=http://isms-core-backend:8000
ISMS_API_TOKEN=<connector-token-from-admin-ui>

# ServiceNow
SNOW_INSTANCE=mycompany   # → mycompany.service-now.com
SNOW_USERNAME=svc_isms
SNOW_PASSWORD=<service-account-password>
SNOW_LOOKBACK_DAYS=30     # pull last 30 days of incidents/changes

# Schedule
POLL_INTERVAL=3600   # 1h — ITSM data changes during the day
BATCH_SIZE=100
