# ============================================================================
# ISMS CORE Platform — Environment Variables
# Copy to .env and fill in ALL values before starting the stack.
# ⚠️  Do not use default values in production — change every line marked CHANGE
# ============================================================================

# ---- Host ----------------------------------------------------------------
# Set HOST_IP to your server's IP address (or hostname)
# This is used for the nginx self-signed cert SAN + frontend API URL
HOST_IP=YOUR_SERVER_IP                        # CHANGE — e.g. 192.168.1.100

# FQDN: set this if using Let's Encrypt (must have certbot + port 80 public)
# Leave empty to use self-signed certificate (auto-generated on first boot — works anywhere)
FQDN=

PLATFORM_URL=https://YOUR_SERVER_IP           # CHANGE — match HOST_IP above
CORS_ORIGINS=https://YOUR_SERVER_IP           # CHANGE — match HOST_IP above

# ---- Secrets (CHANGE ALL OF THESE) --------------------------------------
POSTGRES_PASSWORD=change_this_db_password
REDIS_PASSWORD=change_this_redis_password

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_secret_key_minimum_32_chars

# ---- Admin account -------------------------------------------------------
# Created/updated on every backend startup
ADMIN_EMAIL=admin@isms-core.dev
ADMIN_PASSWORD=change_this_admin_password

# ---- Connectors ----------------------------------------------------------
# Required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
CONNECTORS_WORKER_SECRET=
# Optional tuning (defaults shown):
# RUNNER_REFRESH_INTERVAL=60      # seconds between connector list refresh
# POLL_INTERVAL=86400              # seconds between each connector's sync (24h)

# ---- AI (optional) -------------------------------------------------------
ANTHROPIC_API_KEY=

# ---- Email (choose one profile or leave MAIL_HOST blank to disable) ------
# Leave MAIL_HOST blank to disable email (default — safe for prod with no email configured)
#
# Mailpit (dev mail catcher — never use in prod):
#   docker compose --profile mailpit up -d
#   MAIL_HOST=isms-core-mailpit
#
# SMTP Bridge (M365 / Exchange Online relay — prod email):
#   docker compose --profile smtp-bridge up -d
#   MAIL_HOST=isms-core-smtp-bridge
MAIL_HOST=
MAIL_PORT=1025

# SMTP Bridge credentials (only needed with --profile smtp-bridge)
SMTP_BRIDGE_TENANT_ID=
SMTP_BRIDGE_CLIENT_ID=
SMTP_BRIDGE_CLIENT_SECRET=
SMTP_BRIDGE_FROM_ADDRESS=
SMTP_BRIDGE_FROM_NAME=ISMS CORE
