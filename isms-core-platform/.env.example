# ============================================================================
# ISMS CORE Platform — Production Environment Variables (nuc-02)
# Copy to .env and fill in all values before starting the stack.
# ============================================================================

# ---- Host ----------------------------------------------------------------
HOST_IP=10.0.0.112

# FQDN: set this if using Let's Encrypt (must have certbot installed + port 80 public)
# Leave empty to use self-signed certificate (auto-generated on first boot)
FQDN=

PLATFORM_URL=https://10.0.0.112
CORS_ORIGINS=https://10.0.0.112

# ---- Secrets (CHANGE ALL OF THESE) --------------------------------------
POSTGRES_PASSWORD=change_this_db_password
REDIS_PASSWORD=change_this_redis_password

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_secret_key_minimum_32_chars

# ---- Admin account -------------------------------------------------------
# Created/updated on every backend startup
ADMIN_EMAIL=admin@isms-core.dev
ADMIN_PASSWORD=change_this_admin_password

# ---- Connectors ----------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
CONNECTORS_WORKER_SECRET=

# ---- AI (optional) -------------------------------------------------------
ANTHROPIC_API_KEY=

# ---- Email (choose one profile or leave MAIL_HOST blank to disable) ------
# Mailpit (local catcher):     docker compose --profile mailpit up -d
#   MAIL_HOST=isms-core-mailhog
# SMTP Bridge (M365 relay):    docker compose --profile smtp-bridge up -d
#   MAIL_HOST=isms-core-smtp-bridge
#   SMTP_BRIDGE_TENANT_ID=
#   SMTP_BRIDGE_CLIENT_ID=
#   SMTP_BRIDGE_CLIENT_SECRET=
#   SMTP_BRIDGE_FROM_ADDRESS=
#   SMTP_BRIDGE_FROM_NAME=ISMS CORE
MAIL_HOST=
MAIL_PORT=1025
